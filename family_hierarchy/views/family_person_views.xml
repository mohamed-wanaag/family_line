<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. THE VISUAL CHART VIEW (Hierarchy View) -->
    <record id="view_family_person_hierarchy" model="ir.ui.view">
        <field name="name">family.person.hierarchy</field>
        <field name="model">family.person</field>
        <field name="arch" type="xml">
            <hierarchy child_field="child_ids" draggable="1">
                <field name="full_name"/>
                <field name="occupation"/>
                <field name="image"/>
                <templates>
                    <t t-name="hierarchy-box">
                        <div class="o_hierarchy_node_container d-flex flex-column border rounded p-2 bg-white shadow-sm" style="min-width: 150px;">
                            <div class="o_hierarchy_node_header d-flex align-items-center">
                                <field name="image" widget="image" class="o_hierarchy_node_image me-2" options="{'size': [40, 40]}"/>
                                <div>
                                    <div class="fw-bold text-truncate" style="max-width: 100px;">
                                        <field name="full_name"/>
                                    </div>
                                    <div class="text-muted small">
                                        <field name="occupation"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </hierarchy>
        </field>
    </record>

    <!-- 2. UPDATED FORM VIEW -->
    <record id="view_family_person_form" model="ir.ui.view">
        <field name="name">family.person.form</field>
        <field name="model">family.person</field>
        <field name="arch" type="xml">
            <form string="Family Member">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="alive,deceased"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- THE SMART BUTTON FOR THE CHART -->
                        <button name="action_open_lineage_chart" 
                                type="object" 
                                class="oe_stat_button" 
                                icon="fa-sitemap">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Visual</span>
                                <span class="o_stat_text">Lineage</span>
                            </div>
                        </button>

                        <button name="action_view_children"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users"
                                invisible="child_count == 0">
                            <field name="child_count" widget="statinfo" string="Children"/>
                        </button>
                    </div>

                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>

                    <div class="oe_title">
                        <label for="full_name"/>
                        <h1>
                            <field name="full_name" placeholder="Full Name" required="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Personal Info">
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="age" readonly="1"/>
                            <field name="status"/>
                            <field name="date_of_death"
                                   invisible="status == 'alive'"
                                   required="status == 'deceased'"/>
                        </group>
                        <group string="Background &amp; Family">
                            <field name="occupation"/>
                            <field name="education"/>
                            <field name="parent_id" string="Father/Parent" domain="[('id', '!=', active_id)]"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Children List" name="children">
                            <field name="child_ids" mode="tree">
                                <tree string="Children" editable="bottom">
                                    <field name="full_name"/>
                                    <field name="gender"/>
                                    <field name="date_of_birth"/>
                                    <field name="age"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes about this person..."/>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- TREE VIEW -->
    <record id="view_family_person_tree" model="ir.ui.view">
        <field name="name">family.person.tree</field>
        <field name="model">family.person</field>
        <field name="arch" type="xml">
            <tree string="Family Members" decoration-muted="status == 'deceased'" decoration-success="status == 'alive'">
                <field name="full_name"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="age"/>
                <field name="status" widget="badge" decoration-success="status == 'alive'" decoration-danger="status == 'deceased'"/>
                <field name="occupation"/>
                <field name="parent_id" optional="show"/>
                <field name="child_count" string="Children" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- KANBAN VIEW -->
    <record id="view_family_person_kanban" model="ir.ui.view">
        <field name="name">family.person.kanban</field>
        <field name="model">family.person</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="status">
                <field name="full_name"/>
                <field name="image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_image_fill_left d-none d-md-block"
                                 t-attf-style="background-image:url('#{kanban_image('family.person', 'image', record.id.raw_value)}')"/>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="full_name"/></strong>
                                <ul>
                                    <li><field name="occupation"/></li>
                                    <li>Age: <field name="age"/></li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_family_person_search" model="ir.ui.view">
        <field name="name">family.person.search</field>
        <field name="model">family.person</field>
        <field name="arch" type="xml">
            <search string="Search Family Members">
                <field name="full_name"/>
                <field name="parent_id"/>
                <filter name="filter_alive" string="Alive" domain="[('status','=','alive')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- MAIN ACTION -->
    <record id="action_family_person" model="ir.actions.act_window">
        <field name="name">Family Members</field>
        <field name="res_model">family.person</field>
        <!-- Added 'hierarchy' to view_mode so the chart is available -->
        <field name="view_mode">tree,kanban,hierarchy,form</field>
        <field name="search_view_id" ref="view_family_person_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first family member!</p>
        </field>
    </record>

</odoo>