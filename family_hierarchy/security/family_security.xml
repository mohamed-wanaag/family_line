<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Groups ────────────────────────────────────────────── -->
        <record id="group_family_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_family"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view and create family records, but cannot delete.</field>
        </record>

        <record id="group_family_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_family"/>
            <field name="implied_ids" eval="[(4, ref('group_family_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Full access including delete.</field>
        </record>

    </data>
</odoo>
